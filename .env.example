# Required for @odin/server
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=700

# Rate limits
ODIN_RATE_LIMIT_PER_MINUTE=6
ODIN_RATE_LIMIT_PER_DAY=80

# Server bind
PORT=3030
HOST=0.0.0.0

# For @odin/cli (optional — overrides ~/.odinrc)
ODIN_BASE_URL=http://localhost:3030

# For contracts/ deploy scripts (optional)
RPC_URL=
MAINNET_RPC_URL=
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
